KRAKEN_API_KEY=
KRAKEN_API_SECRET=

# ---------------------------------------------------------------------------
# Alpaca — free paper + live crypto/stock trading (Texas-compliant)
# ---------------------------------------------------------------------------
# Free paper account at https://alpaca.markets → Paper Trading → API Keys
# Enables: SPY/VIX data (stable, no yfinance issues), crypto bid-ask spread,
# BTC/ETH paper/live trading, portfolio tracking via MCP in Cursor.
ALPACA_API_KEY=
ALPACA_SECRET_KEY=
ALPACA_PAPER=true

# ---------------------------------------------------------------------------
# Coinbase Advanced Trade — CDP (JWT) authentication (Texas-compliant)
# ---------------------------------------------------------------------------
# Full-access key (portfolio reads, order placement)
# Key name: organizations/{org_id}/apiKeys/{key_id}
COINBASE_CDP_KEY_NAME=
# EC private key — store as single line with \n literals (NOT real newlines)
COINBASE_CDP_PRIVATE_KEY=-----BEGIN EC PRIVATE KEY-----\n<base64>\n-----END EC PRIVATE KEY-----\n
# Limited/read-only key (market data only, no account access)
COINBASE_KEY_ID=
COINBASE_KEY_SECRET=

# Gemini (Texas-compliant — add keys when ready)
# GEMINI_API_KEY=
# GEMINI_API_SECRET=

# ---------------------------------------------------------------------------
# Oanda REST v20 (CFD crypto + forex — available in Texas, paper trading supported)
# ---------------------------------------------------------------------------
# Access token: https://www.oanda.com/account/#/access/fxtrade/personal-token
OANDA_ACCESS_TOKEN=
# Account ID — run: python -m hogan_bot.fetch_oanda --list-accounts
OANDA_ACCOUNT_ID=
# "practice" = paper trading (fxTrade Practice), "live" = real money
OANDA_ENVIRONMENT=practice

HOGAN_EXCHANGE=kraken
# Oanda FX paper trading — uses OandaDataEngine + RealisticPaperExecution
#   Set HOGAN_USE_OANDA=true (or HOGAN_EXCHANGE=oanda) to switch data + execution to Oanda.
#   Works in both paper and live mode. Requires OANDA_ACCESS_TOKEN + OANDA_ACCOUNT_ID above.
HOGAN_USE_OANDA=false
# Kraken WebSocket fallback — if WS fails (e.g. "GET /0/public/Assets" errors):
#   HOGAN_USE_REST_DATA=1     — skip WebSocket, use REST polling from start
#   HOGAN_WS_FAIL_THRESHOLD=5 — after 5 consecutive WS failures, switch to REST (default)
HOGAN_STARTING_BALANCE=1800
HOGAN_AGGRESSIVE_ALLOCATION=0.75
HOGAN_MAX_RISK_PER_TRADE=0.03
HOGAN_MAX_DRAWDOWN=0.15
HOGAN_SYMBOLS=BTC/USD,ETH/USD
HOGAN_TIMEFRAME=1h
HOGAN_OHLCV_LIMIT=500
HOGAN_SHORT_MA=20
HOGAN_LONG_MA=50
HOGAN_VOLUME_WINDOW=20
HOGAN_VOLUME_THRESHOLD=1.2
HOGAN_FEE_RATE=0.0026
HOGAN_SLEEP_SECONDS=30
HOGAN_TRADE_WEEKENDS=false
HOGAN_PAPER_MODE=true
HOGAN_USE_ML_FILTER=false
HOGAN_ML_MODEL_PATH=models/hogan_logreg.pkl
HOGAN_ML_BUY_THRESHOLD=0.55
HOGAN_ML_SELL_THRESHOLD=0.45
HOGAN_USE_EMA_CLOUDS=false
HOGAN_EMA_FAST_SHORT=8
HOGAN_EMA_FAST_LONG=9
HOGAN_EMA_SLOW_SHORT=34
HOGAN_EMA_SLOW_LONG=50
HOGAN_USE_FVG=false
HOGAN_FVG_MIN_GAP_PCT=0.001
HOGAN_SIGNAL_MODE=any
HOGAN_TRAILING_STOP_PCT=0.0
HOGAN_TAKE_PROFIT_PCT=0.0
HOGAN_ATR_STOP_MULTIPLIER=1.5
# Reinforcement Learning agent (train with: python -m hogan_bot.rl_train)
HOGAN_USE_RL_AGENT=false
HOGAN_RL_MODEL_PATH=models/hogan_rl_policy.zip
HOGAN_RL_REWARD_TYPE=risk_adjusted
HOGAN_RL_TIMESTEPS=200000
# ICT signal pillars (all off by default)
HOGAN_USE_ICT=false
HOGAN_ICT_MODEL=silver_bullet
HOGAN_ICT_SWING_LEFT=2
HOGAN_ICT_SWING_RIGHT=2
HOGAN_ICT_EQ_TOLERANCE_PCT=0.0008
HOGAN_ICT_MIN_DISPLACEMENT_PCT=0.003
HOGAN_ICT_REQUIRE_TIME_WINDOW=true
HOGAN_ICT_TIME_WINDOWS=03:00-04:00,10:00-11:00,14:00-15:00
HOGAN_ICT_REQUIRE_PD=true
HOGAN_ICT_OTE_ENABLED=false
HOGAN_ICT_OTE_LOW=0.62
HOGAN_ICT_OTE_HIGH=0.79
# Scale position size by ML model confidence (|prob-0.5|*2). Requires HOGAN_USE_ML_FILTER=true
HOGAN_ML_CONFIDENCE_SIZING=true
# Webhook URL for trade/drawdown notifications (leave blank to disable)
HOGAN_WEBHOOK_URL=
# Walk-forward retraining defaults (python -m hogan_bot.retrain)
HOGAN_RETRAIN_WINDOW_BARS=5000
HOGAN_RETRAIN_MODEL_TYPE=logreg
HOGAN_RETRAIN_MIN_IMPROVEMENT=0.005
HOGAN_RETRAIN_PROMOTION_METRIC=roc_auc
HOGAN_RETRAIN_SCHEDULE_HOURS=24
# External data API keys
COINAPI_KEY=
CRYPTOQUANT_KEY=
# CoinMarketCap Pro API — free Basic plan (10k credits/month) at pro.coinmarketcap.com
# Used by: python -m hogan_bot.fetch_cmc  (runs daily via refresh_daily.py)
# Provides: BTC/ETH dominance, total market cap, DeFi%, stablecoin%, 24h/7d momentum
# Cost:     ~90 credits/month for daily global metrics + BTC/ETH quotes
# Fills:    CoinGecko feature slots (cg_btc_dominance, cg_mcap_change_24h, etc.)
CMC_API_KEY=

# CoinGecko Demo API — free at https://www.coingecko.com/en/api  (optional — CMC covers same data)
# Used by: python -m hogan_bot.fetch_coingecko [--backfill]
COINGECKO_KEY=
# CryptoPanic — free token at https://cryptopanic.com/developers/api/
# Used by: python -m hogan_bot.fetch_news_sentiment [--pages 5]
# Provides: BTC news sentiment score + daily story volume
CRYPTOPANIC_KEY=
# Glassnode — paid API at https://glassnode.com/pricing (~$29+/mo Standard tier)
# Used by: python -m hogan_bot.fetch_glassnode [--days 365]
# Provides: exchange net flow, realized price distance, Puell Multiple
GLASSNODE_KEY=
# Santiment — paid API at https://app.santiment.net/pricing ($49/mo Sanbase Pro)
# Used by: python -m hogan_bot.fetch_santiment [--days 365]
# Provides: BTC social volume % change, developer activity % change
SANTIMENT_KEY=

# ---------------------------------------------------------------------------
# Champion mode, execution, and runtime controls
# ---------------------------------------------------------------------------
# Champion mode locks feature flags to the proven production config
HOGAN_CHAMPION_MODE=false

# Edge gate: minimum edge-over-friction multiple to allow a trade
HOGAN_MIN_EDGE_MULTIPLE=1.5

# Entry quality gate thresholds
HOGAN_MIN_FINAL_CONFIDENCE=0.25
HOGAN_MIN_TECH_CONFIDENCE=0.15
HOGAN_MIN_REGIME_CONFIDENCE=0.3
HOGAN_MAX_WHIPSAWS=3
# Asymmetric reversal: require stronger confidence to exit than to enter
HOGAN_REVERSAL_CONFIDENCE_MULT=1.3

# Allow short positions (in addition to long)
HOGAN_ALLOW_SHORTS=false

# Short selling in live/paper event loop (regime-gated: volatile + trending_down)
HOGAN_ENABLE_SHORTS=true
HOGAN_CLOSE_AND_REVERSE=false

# Macro event sit-out filter: blocks trades on FOMC/CPI/NFP days,
# scales down during extreme greed, VIX-based caution.
# Validated: halves losses during FOMO rallies, preserves edge during fear.
HOGAN_MACRO_SITOUT=true

# Use regime detection for gating
HOGAN_USE_REGIME_DETECTION=true

# Hold / cooldown controls (optional, auto-derived from timeframe if absent)
# HOGAN_MAX_HOLD_HOURS=24
# HOGAN_LOSS_COOLDOWN_HOURS=4
HOGAN_SHORT_MAX_HOLD_HOURS=12
HOGAN_MIN_HOLD_BARS=3
HOGAN_EXIT_CONFIRM_BARS=2

# Execution mode
HOGAN_USE_OANDA=false
HOGAN_SMART_EXEC=false
HOGAN_EXEC_MAX_REPRICES=2
HOGAN_EXEC_CHASE_BPS=2.0

# Realistic paper execution (slippage + spread simulation)
HOGAN_REALISTIC_PAPER=true
HOGAN_SLIPPAGE_BPS=5.0
HOGAN_SPREAD_HALF_BPS=3.0

# Persistence
HOGAN_DB_PATH=data/hogan.db

# Live trading (DANGEROUS). Requires ALL THREE:
#   HOGAN_PAPER_MODE=false
#   HOGAN_LIVE_MODE=true
#   HOGAN_LIVE_ACK=I_UNDERSTAND_LIVE_TRADING
HOGAN_LIVE_MODE=false
HOGAN_LIVE_ACK=

# Monitoring / Notifications
HOGAN_METRICS_PORT=8000

# Discord (primary notification channel)
# Create: Server Settings → Integrations → Webhooks → New Webhook → Copy URL
HOGAN_DISCORD_WEBHOOK_URL=

# Generic JSON webhook fallback (Slack, Make.com, Zapier, etc.)
HOGAN_WEBHOOK_URL=

# Email (optional)
HOGAN_EMAIL_SMTP_HOST=
HOGAN_EMAIL_SMTP_PORT=587
HOGAN_EMAIL_USERNAME=
HOGAN_EMAIL_PASSWORD=
HOGAN_EMAIL_FROM=
HOGAN_EMAIL_TO=

# Account valuation currency
HOGAN_QUOTE_CCY=USD

# ---------------------------------------------------------------------------
# LLM providers (hogan_bot/trade_explainer.py)
# ---------------------------------------------------------------------------
# Options: "openai" (cloud) or "ollama" (local, free)
HOGAN_LLM_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
# Ollama (local LLM server — run: ollama serve)
HOGAN_OLLAMA_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# On-chain / Fundamentals APIs
# ---------------------------------------------------------------------------
# CoinAPI — OHLCV backfill (https://coinapi.io — free tier 100 req/day)
COINAPI_KEY=

# Messari crypto fundamentals — NVT, realized cap, ROI, dev activity
# Free tier at https://messari.io/api (~1000 req/day)
MESSARI_KEY=

# Dune Analytics — BTC exchange flow, whale count via SQL queries
# API key at https://dune.com/settings/api
DUNE_API_KEY=

# ---------------------------------------------------------------------------
# Data Provider APIs (already configured above, listed here for reference)
# ---------------------------------------------------------------------------
# COINGECKO_KEY    — free at https://www.coingecko.com/en/api
# CRYPTOPANIC_KEY  — free at https://cryptopanic.com/developers/api/
# GLASSNODE_KEY    — paid at https://glassnode.com/pricing
# SANTIMENT_KEY    — paid at https://app.santiment.net/pricing
# CRYPTOQUANT_KEY  — paid at https://cryptoquant.com
