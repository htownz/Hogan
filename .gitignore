.venv/
.venv-linux/
.venv_wsl/
__pycache__/
*.pyc
.env
.env.local

# ML models — binary, large, machine-specific
models/*.pkl
models/*.zip
models/registry.jsonl

# SQLite databases — large, machine-specific runtime data
*.db
data/*.db
hogan_trades.db

# SQLite temporary files — auto-generated, environment-specific
*.db-wal
*.db-shm

# Backup files — use version control instead
*.bak
*.backup
*~

# IDE and editor config
.idea/
.vscode/
*.swp
*.swo

# Personal developer notes (machine-specific paths, scratch commands)
Command Prompts.md

# Secret / key files — NEVER commit these
API Keys.txt
*.key
*.pem
secrets.txt

# Logs — keep structure but ignore contents
logs/*.log
.pytest_cache
mlruns/

# Diagnostics output
diagnostics/*.json
